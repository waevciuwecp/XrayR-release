    // =========================================================================
    // Blackhole — silently drop matching traffic.
    // Used with route.json to block private IPs, BitTorrent, ads, etc.
    // Set response.type to "http" or "none".
    // =========================================================================
    {
        "tag": "block",
        "protocol": "blackhole",
        "settings": {
            "response": {
                "type": "none"
            }
        }
    }
]
