    // =========================================================================
    // Shadowsocks Outbound — forward traffic to an upstream SS server.
    // NOTE: server params MUST be inside a "servers" array, otherwise
    // Xray core panics with "0 Shadowsocks server configured."
    // =========================================================================
    {
        "tag": "ss_to_jellyfish",
        "sendThrough": "0.0.0.0",
        "protocol": "shadowsocks",
        "settings": {
            "servers": [
                {
                    "address": "CHANGE_ME_SS_REMOTE_IP",
                    "port": 30001,
                    "method": "aes-256-gcm",
                    "password": "CHANGE_ME_SS_REMOTE_PASS",
                    "level": 0,
                    "email": "you@email.com"
                }
            ]
        }
    },

