[
    // =========================================================================
    // Direct (Freedom) — send traffic directly. The default-first outbound.
    // Add a UseIPv6 variant for routing IPv6-only destinations (e.g. Netflix).
    // =========================================================================
    {
        "tag": "IPv4_out",
        "protocol": "freedom",
        "settings": {}
    },
    {
        "tag": "IPv6_out",
        "protocol": "freedom",
        "settings": {
            "domainStrategy": "UseIPv6"
        }
    },

    // =========================================================================
    // SOCKS5 Outbound — tunnel traffic through an upstream SOCKS5 server.
    // Common use case: route traffic through WARP (localhost:1080).
    // =========================================================================
    {
        "tag": "socks5-warp",
        "protocol": "socks",
        "settings": {
            "servers": [
                {
                    "address": "127.0.0.1",
                    "port": 1080
                }
            ]
        }
    },

