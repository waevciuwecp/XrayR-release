[
    // =========================================================================
    // SOCKS5 Inbound — expose a local SOCKS5 proxy on the server
    // =========================================================================
    {
        "listen": "127.0.0.1",
        "port": 1080,
        "protocol": "socks",
        "settings": {
            "auth": "password",
            "accounts": [
                {
                    "user": "CHANGE_ME_USER",
                    "pass": "CHANGE_ME_PASS"
                }
            ],
            "udp": true,
            "userLevel": 0
        },
        "tag": "socks_in"
    },

    // =========================================================================
    // HTTP Inbound — local HTTP/HTTPS proxy (no auth)
    // =========================================================================
    {
        "listen": "127.0.0.1",
        "port": 8080,
        "protocol": "http",
        "settings": {
            "userLevel": 0
        },
        "tag": "http_in"
    },

    // =========================================================================
    // Dokodemo-Door Inbound — forward a local port to a fixed remote destination.
    // Useful for transparent proxying, port forwarding, or game servers.
    // =========================================================================
    {
        "listen": "127.0.0.1",
        "port": 9000,
        "protocol": "dokodemo-door",
        "settings": {
            "address": "1.1.1.1",
            "port": 443,
            "network": "tcp"
        },
        "tag": "doko_in"
    }

